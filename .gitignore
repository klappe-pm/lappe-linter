# Intellij
*.iml
.idea

# VSCode
.vscode/*
!/.vscode/settings.json

# npm
node_modules

# build
*.js
*.js.map
!eslint-rules/*.js

# obsidian
data.json

# test vault
test-vault/.obsidian/*.json
# keep activated community plugin list
!test-vault/.obsidian/community-plugins.json
# plugins
!test-vault/.obsidian/plugins/hot-reload/*
test-vault/.obsidian/plugins/lappe-linter/*
!test-vault/.obsidian/plugins/lappe-linter/.hotreload
!test-vault/.obsidian/plugins/lappe-linter/data.json
!test-vault/.obsidian/plugins/lappe-linter/manifest.json
test-vault/.obsidian/plugins/table-editor-obsidian/*
!test-vault/.obsidian/plugins/table-editor-obsidian/.gitkeep

# occasional bug fix test
main.zip

# ignore generated files
main.js
styles.css

yarn.lock

.DS_Store

!__mocks__/*.js
!/.eslintrc.js
!babel.config.js
!postcss.config.js

# workspace build output
packages/*/dist/

# re-include jest test dirs caught by the global **/_*/ ignore
!**/__tests__/
!**/__mocks__/
!**/__integration__/

# built plugin drop-in folder
dist-plugin/

# Session rigor anchor (local only)
.claude-session-scope

# Repo-root Obsidian vault config (local only; test-vault/.obsidian is a tracked fixture)
/.obsidian/
