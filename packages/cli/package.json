{
  "name": "@lappe-linter/cli",
  "version": "1.32.0",
  "description": "Headless lappe-linter runner for hooks and CI. Runs @lappe-linter/core rules against files on disk with no Obsidian dependency.",
  "license": "MIT",
  "bin": {
    "lappe-linter": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "tsc -p ../core/tsconfig.json && esbuild src/index.ts --bundle --platform=node --minify --outfile=dist/lappe-linter-bundle.cjs",
    "start": "node --loader ts-node/esm src/index.ts",
    "test": "jest"
  },
  "dependencies": {
    "@lappe-linter/core": "*"
  }
}
